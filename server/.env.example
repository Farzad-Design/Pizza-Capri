# Copy to .env and fill in for this restaurant instance. Never commit .env.

PORT=3000
NODE_ENV=production
SITE_URL=https://example.com

# Where SQLite data, images and backups are stored.
DATA_DIR=./data

# Required. Also used as the encryption key for stored payment secrets, and
# accepted as a header/query fallback for admin API access (x-admin-secret).
ADMIN_SECRET=change-me-to-a-long-random-string

# How long a completed order stays in the database (GDPR data minimisation).
ORDER_RETENTION_DAYS=60

# PrintNode (kitchen receipt printing). Can also be set from the admin panel,
# which takes precedence over these env vars.
PRINTNODE_API_KEY=
PRINTNODE_PRINTER_ID=

# Resend (transactional email: registration, order confirmation, password reset).
RESEND_API_KEY=
EMAIL_FROM="Restaurant <orders@example.com>"
